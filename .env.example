# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
# Optional for future queues/cache. Current app code does not require Redis.
REDIS_URL=""

# App URLs
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
SESSION_SECRET="replace-with-32-byte-random-secret"
CRON_SECRET="replace-with-long-random-secret"

# Temporary test login. Keep false in production unless explicitly testing.
ENABLE_TEST_LOGIN="false"
# Extra safety gate. Keep false unless you intentionally need test-login on a hosted production-like environment.
ALLOW_PRODUCTION_TEST_LOGIN="false"
TEST_ADMIN_PASSWORD=""
TEST_STUDENT_PASSWORD=""
TEST_TEACHER_PASSWORD=""

# Firebase client
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Firebase admin
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Payments - Razorpay. Leave empty until client credentials are available.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Payments - PayPal. Use sandbox for staging/testing, live for production.
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
PAYPAL_ENV="sandbox"
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""

# Payments - Bank transfer
BANK_TRANSFER_ACCOUNT_NAME=""
BANK_TRANSFER_BANK_NAME=""
BANK_TRANSFER_ACCOUNT_NUMBER=""
BANK_TRANSFER_SWIFT=""
BANK_TRANSFER_IBAN=""

# Email - Gmail SMTP (Recommended for small volume)
GMAIL_EMAIL="your-email@gmail.com"
GMAIL_APP_PASSWORD="your-16-character-google-app-password"
ADMIN_EMAIL="admin@example.com"
SUPPORT_EMAIL="info@example.com"

# Email - Alternative: Resend (Better for high volume)
RESEND_API_KEY=""
EMAIL_FROM="Bali YTTC <noreply@example.com>"
BREVO_API_KEY=""

# EmailJS (for contact form - frontend only)
NEXT_PUBLIC_CONTACT_EMAIL="info@example.com"
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=""
NEXT_PUBLIC_EMAILJS_SERVICE_ID=""
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=""
NEXT_PUBLIC_EMAILJS_ADMIN_TEMPLATE_ID=""

# WhatsApp Cloud API. Leave empty if only the floating WhatsApp link is needed.
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
