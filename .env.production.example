# Copy this file to .env.production on the VPS.
# Never commit .env.production.

# VPS database containers
POSTGRES_USER=baliyttc
POSTGRES_PASSWORD=replace-with-long-random-password
POSTGRES_DB=baliyttc
# docker-compose.vps.yml builds DATABASE_URL from the values above.
# If deploying outside Docker Compose, set DATABASE_URL directly:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# Optional for future queues/cache. docker-compose.vps.yml provides this automatically.
REDIS_URL=redis://redis:6379

# App URLs
NEXT_PUBLIC_BASE_URL=https://baliyttc.com
SESSION_SECRET=replace-with-32-plus-character-random-secret
CRON_SECRET=replace-with-long-random-cron-secret

# Temporary test login. Keep disabled after handoff or when real Firebase users are active.
ENABLE_TEST_LOGIN=false
TEST_ADMIN_PASSWORD=
TEST_STUDENT_PASSWORD=
TEST_TEACHER_PASSWORD=

# Firebase client app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Payments: Razorpay + PayPal are currently implemented. Leave provider keys empty
# until the client account is ready; the app will hide unavailable methods.
# If client chooses Stripe later, add Stripe back as a separate payment module.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=live
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Bank transfer fallback
BANK_TRANSFER_ACCOUNT_NAME=
BANK_TRANSFER_BANK_NAME=
BANK_TRANSFER_ACCOUNT_NUMBER=
BANK_TRANSFER_SWIFT=
BANK_TRANSFER_IBAN=

# Email - Gmail SMTP
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
ADMIN_EMAIL=

# Email - Alternative providers
RESEND_API_KEY=
BREVO_API_KEY=

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Optional legacy/contact fallback
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_ADMIN_TEMPLATE_ID=
