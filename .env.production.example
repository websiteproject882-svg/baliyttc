# Copy this file to .env.production on the VPS.
# Never commit .env.production.

# VPS database containers
POSTGRES_USER=baliyttc
POSTGRES_PASSWORD=replace-with-long-random-password
POSTGRES_DB=baliyttc

# App URLs
NEXT_PUBLIC_BASE_URL=https://baliyttc.com
SESSION_SECRET=replace-with-32-plus-character-random-secret
CRON_SECRET=replace-with-long-random-cron-secret

# Firebase client app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Payments: Razorpay + PayPal are currently implemented.
# If client chooses Stripe later, add Stripe back as a separate payment module.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=live
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Bank transfer fallback
BANK_TRANSFER_ACCOUNT_NAME=
BANK_TRANSFER_BANK_NAME=
BANK_TRANSFER_ACCOUNT_NUMBER=
BANK_TRANSFER_SWIFT=
BANK_TRANSFER_IBAN=

# Email
RESEND_API_KEY=
BREVO_API_KEY=

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Optional legacy/contact fallback
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_ADMIN_TEMPLATE_ID=
